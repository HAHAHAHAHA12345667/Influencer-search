# Copy this file to outputs/.env and add only the keys you have.
# Never commit outputs/.env or paste keys into a chat or public repository.

YOUTUBE_API_KEY=
MODASH_API_KEY=

# Email outreach (leave blank until you are ready to send a reviewed small batch).
# Gmail usually needs an App Password; a Google Workspace or transactional-email
# SMTP inbox is preferable for a real business workflow.
OUTREACH_SMTP_HOST=
OUTREACH_SMTP_PORT=587
OUTREACH_SMTP_USERNAME=
OUTREACH_SMTP_PASSWORD=
OUTREACH_FROM_EMAIL=
OUTREACH_POSTAL_ADDRESS=
OUTREACH_UNSUBSCRIBE_EMAIL=
